@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam style strictuml
hide empty members

package inscryption {

    package logique {

        abstract class CarteLogic <<abstract>> {
            - m_nom : String
            - m_pointsVieMax : Integer
            - m_pointsVieActuels : Integer
            - m_pointsAttaque : Integer
            # m_pouvoirs : List<Pouvoir>
            + <<Create>> CarteLogic(nom : String, pv : Integer, att : Integer)
            + {abstract} attaquer(caseEnFace : Emplacement, score : ScoreLogic, messages : String[*], plateau : PlateauLogic)
            + getPouvoirs() : List<Pouvoir>
            + ajouterPouvoir(pouvoir : Pouvoir)
            + retirerPouvoirs() : List<Pouvoir>
            + getNom() : String
            + getPointsVieMax() : Integer
            + getPointsVieActuels() : Integer
            + getPointsAttaque() : Integer
            + estMorte() : Boolean
            + recevoirDegats(valeur : Integer)
            + setAttaque(valeur : Integer)
            + setPv(valeur : Integer)
            + setNom(nom : String)
            + setPvMax(val : Integer)
            + incrementerToursSurPlateau()
            + getToursSurPlateau() : Integer
        }

        class CarteObstacleLogic extends CarteLogic {
            + <<Create>> CarteObstacleLogic(nom: String, pv: Integer)
            + attaquer(caseEnFace : Emplacement, score : ScoreLogic, messages : String[*], plateau : PlateauLogic)
        }

        class CarteAnimalLogic extends CarteLogic {
            - m_coutSang : Integer
            - m_coutOs : Integer
            - m_toursSurPlateau : Integer
            + <<Create>> CarteAnimalLogic(nom: String, pv: Integer, att: Integer, sang: Integer, os: Integer)
            + attaquer(caseEnFace : Emplacement, score : ScoreLogic, messages : String[*], plateau : PlateauLogic)
            + getCoutSang() : Integer
            + getCoutOs() : Integer
            + incrementerToursSurPlateau()
            + getToursSurPlateau() : Integer
        }

        class CarteVolanteLogic extends CarteAnimalLogic {
            + <<Create>> CarteVolanteLogic(nom: String, pv: Integer, att: Integer, sang: Integer, os: Integer)
            + attaquer(caseEnFace : Emplacement, score : ScoreLogic, messages : String[*], plateau : PlateauLogic)
        }

        abstract class Pouvoir <<abstract>> {
            + {abstract} getNom() : String
            + auDebutTour(carte : CarteLogic, caseActuelle : Emplacement)
            + auCalculAttaque(degatsBruts : Integer, attaquant : CarteLogic, cible : CarteLogic, plateau : PlateauLogic) : Integer
            + apresRecevoirDegats(cible : CarteLogic, attaquant : CarteLogic, degatsRecus : Integer, plateau : PlateauLogic)
            + auSacrifice(carteSacrifiee : CarteLogic) : Boolean
            + auMouvement(carte : CarteLogic, caseActuelle : Emplacement, plateau : PlateauLogic)
        }

        class NombreusesVies extends Pouvoir {
            + getNom() : String
            + auSacrifice(carteSacrifiee : CarteAnimalLogic) : Boolean
        }

        class Croissance extends Pouvoir {
            + getNom() : String
            + auDebutTour(carte : CarteLogic, caseActuelle : Emplacement)
        }

        class Puant extends Pouvoir {
            + getNom() : String
            + auCalculAttaque(degatsBruts : Integer, attaquant : CarteLogic, cible : CarteLogic, plateau : PlateauLogic) : Integer
        }

        class Coureur extends Pouvoir {
            + getNom() : String
            + auMouvement(carte : CarteLogic, caseActuelle : Emplacement, plateau : PlateauLogic)
        }

        class ContactMortel extends Pouvoir {
            + getNom() : String
            + apresRecevoirDegats(cible : CarteLogic, attaquant : CarteLogic, degatsRecus : Integer, plateau : PlateauLogic)
        }

        class PiquePointues extends Pouvoir {
            + getNom() : String
            + apresRecevoirDegats(cible : CarteLogic, attaquant : CarteLogic, degatsRecus : Integer, plateau : PlateauLogic)
        }

        class FabriqueCartes {
            + {static} creerChat() : CarteAnimalLogic
            + {static} creerGrizzly() : CarteAnimalLogic
            + {static} creerCoyote() : CarteAnimalLogic
            + {static} creerMoineau() : CarteVolanteLogic
            + {static} creerCorbeau() : CarteVolanteLogic
            + {static} creerEcureuil() : CarteAnimalLogic
            + {static} creerHermine() : CarteAnimalLogic
            + {static} creerLouveteau() : CarteAnimalLogic
            + {static} creerLoup() : CarteAnimalLogic
            + {static} creerPunaise() : CarteAnimalLogic
            + {static} creerRocher() : CarteObstacleLogic
            + {static} creerSapin() : CarteObstacleLogic
        }

        class Emplacement {
            - m_position : Integer
            + <<Create>> Emplacement(position : Integer)
            + getPosition() : Integer
            + estVide() : Boolean
            + getCarteContenue() : CarteLogic
            + placerCarte(carte : CarteLogic)
            + liberer()
        }

        class PlateauLogic {
            + <<Create>> PlateauLogic()
            + AppliquerEffetsDebutTour(campJoueur : Boolean)
            + avancerMouvements(campJoueur : Boolean)
            + resoudreAttaques(campJoueur : Boolean, score : ScoreLogic) : String[*]
            + appliquerDegatsDirects(degats : Integer, attaquant : CarteLogic, score : ScoreLogic, messages : String[*])
            + trouverCaseAdjacente(caseActuelle : Emplacement) : Emplacement
            + getCasesJoueur() : Emplacement[*]
            + getCasesAdversaire() : Emplacement[*]
        }

        class ScoreLogic {
            - m_valeurRelative : Integer
            + <<Create>> ScoreLogic()
            + ajouterPointsJoueur(points : Integer)
            + ajouterPointsAdversaire(points : Integer)
            + getValeurRelative() : Integer
            + estPartieTerminee() : Boolean
            + getGagnant() : String[0..1]
        }

        class JoueurLogic {
            - m_reserveOs : Integer
            - m_nombreCartesMain : Integer
            - m_nombreCartesDeck : Integer
            - m_nombreEcureuils : Integer
            + <<Create>> JoueurLogic()
            - initialiserDeck()
            + ajouterCarteDeck(carte : CarteAnimalLogic)
            + ajouterEcureuil(carte : CarteAnimalLogic)
            + piocherCartePrincipal()
            + piocherEcureuil()
            + ajouterOs(quantite : Integer)
            + consommerOs(quantite : Integer)
            + getReserveOs() : Integer
            + getMain() : CarteAnimalLogic[*]
            + getNombreCartesMain() : Integer
        }

        class AdversaireLogic {
            + <<Create>> AdversaireLogic(plan : PlanJeu)
            + obtenirIntention(tour : Integer) : CarteLogic[*]
            + jouerTour(tour : Integer, plateau : PlateauLogic)
        }

        class PlanJeu {
            - m_sequencesApparition : CarteLogic[10][4]
            + <<Create>> PlanJeu()
            - initialiserPlan()
            + getCartesPourTour(tour : Integer) : CarteLogic[*]
        }
    }

    package affichage {

        class InterfaceConsole {
            + afficherEtatJeu(plateau : PlateauLogic, joueur : JoueurLogic, score : ScoreLogic, tour : Integer, intentions : CarteLogic[*])
            + afficherPlateau(plateau : PlateauLogic)
            + afficherMain(joueur : JoueurLogic)
            + afficherMessages(messages : String[*])
            + lireSaisie() : String
        }

        class AnalyseurSaisie {
            + <<Create>> AnalyseurSaisie()
            + interpreter(saisie : String) : Commande
        }

        class Commande {
            - m_action : String
            - m_indexCarteMain : Integer[0..1]
            - m_positionPlateau : Integer[0..1]
            + <<Create>> Commande(action : String)
            + <<Create>> Commande(action : String, indexCarteMain : Integer, positionPlateau : Integer)
            + getAction() : String
            + getIndexCarteMain() : Integer[0..1]
            + getPositionPlateau() : Integer[0..1]
        }

        class GestionnairePartie {
            - m_tour : Integer
            + <<Create>> GestionnairePartie()
            + executerJeu()
            - phaseDePioche()
            - boucleTourJoueur()
            + {static} main(args : String[*])
        }
    }
}

' --- Relations de structure ---
CarteLogic o--> "*\n- m_pouvoirs" Pouvoir : > possède

Emplacement o--> "0..1\n- m_carteContenue" CarteLogic : > contient

PlateauLogic *--> "*\n- m_casesJoueur" Emplacement : > aligne
PlateauLogic *--> "*\n- m_casesAdversaire" Emplacement : > aligne

JoueurLogic o--> "*\n- m_main" CarteAnimalLogic : > possède
JoueurLogic o--> "*\n- m_deckPrincipal" CarteAnimalLogic : > possède
JoueurLogic o--> "*\n- m_pileEcureuils" CarteAnimalLogic : > possède

AdversaireLogic *--> "1\n- m_planJeu" PlanJeu : > suit

GestionnairePartie *--> "1\n- m_plateau" PlateauLogic : > contrôle
GestionnairePartie *--> "1\n- m_joueur" JoueurLogic : > régit
GestionnairePartie *--> "1\n- m_adversaire" AdversaireLogic : > simule
GestionnairePartie *--> "1\n- m_score" ScoreLogic : > comptabilise
GestionnairePartie *--> "1\n- m_vue" InterfaceConsole : > met à jour
GestionnairePartie *--> "1\n- m_analyseur" AnalyseurSaisie : > utilise

' --- Dépendances de paramètres ---
Pouvoir ..> PlateauLogic : <<uses>>
Pouvoir ..> CarteLogic : <<uses>>
Pouvoir ..> Emplacement : <<uses>>

' --- Autres Dépendances ---
FabriqueCartes ..> CarteAnimalLogic : <<instantiate>>
FabriqueCartes ..> CarteVolanteLogic : <<instantiate>>
FabriqueCartes ..> CarteObstacleLogic : <<instantiate>>

AnalyseurSaisie ..> Commande : <<create>>
GestionnairePartie ..> Commande : <<uses>>
GestionnairePartie ..> FabriqueCartes : <<uses>>

@enduml